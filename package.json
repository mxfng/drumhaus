    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxlint": "^1.65.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vite": "^8.0.13"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
