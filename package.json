  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
